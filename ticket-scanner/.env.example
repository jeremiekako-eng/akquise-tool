# ── API Keys ──────────────────────────────────────────────
# Ticketmaster Discovery API (kostenlos): https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_key_here

# SeatGeek API (kostenlos): https://platform.seatgeek.com/
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_here
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_here

# ── Scanner-Einstellungen ──────────────────────────────────
# Länder/Städte filtern (kommagetrennt)
TARGET_COUNTRIES=DE,AT,CH
TARGET_CITIES=Berlin,Hamburg,München,Frankfurt,Köln,Wien,Zürich

# Kategorien (Music,Sports,Arts,Family,Comedy)
TARGET_CATEGORIES=Music,Sports

# ── Profit-Parameter ──────────────────────────────────────
# Minimaler ROI in % für "Buy"-Signal
MIN_ROI_BUY=30
# Minimaler ROI in % für "Maybe"-Signal
MIN_ROI_MAYBE=15

# Plattform-Gebühren in %
STUBHUB_FEE_PERCENT=15
VIAGOGO_FEE_PERCENT=15
TICKETMASTER_RESALE_FEE_PERCENT=10

# Sicherheitspuffer für unerwartete Kosten (€)
COST_BUFFER=5.0

# ── Alert-Einstellungen ───────────────────────────────────
# Email-Alerts (optional)
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=your_email@gmail.com

# Mindest-Profit für Alert (€)
ALERT_MIN_PROFIT=20.0

# ── Scan-Intervall ─────────────────────────────────────────
# Wie oft scannen (Minuten)
SCAN_INTERVAL_MINUTES=30
